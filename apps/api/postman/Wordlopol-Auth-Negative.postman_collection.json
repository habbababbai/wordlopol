{
  "info": {
    "name": "Wordlopol Auth (negative)",
    "description": "Edge-case and error responses for the auth API.\n\nUses the same **Wordlopol Local** environment as the happy-path collection.\n\nRun the full collection or individual folders. Requests named `[init]` reset a fresh user for that scenario.\n\nRequires NODE_ENV=development (devToken on register).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3001/v1"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (pm.info.requestName.includes('[init]')) {",
          "  const runId = Date.now();",
          "  pm.environment.set('email', `neg-${runId}@example.com`);",
          "  pm.environment.set('password', 'secure-password');",
          "  pm.environment.set('display_name', 'Player');",
          "  pm.environment.set('access_token', '');",
          "  pm.environment.set('verify_token', '');",
          "  pm.environment.set('reset_token', '');",
          "  console.log('[init]', pm.environment.get('email'));",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "01 Login before verify → 403",
      "item": [
        {
          "name": "Neg 01 [init] Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.environment.set('verify_token', pm.response.json().devToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"displayName\": \"{{display_name}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/auth/register"
          }
        },
        {
          "name": "Neg 01 Login expect 403",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 403', () => pm.response.to.have.status(403));",
                  "pm.test('Email not verified', () => {",
                  "  pm.expect(pm.response.json().error).to.eql('Email not verified');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/auth/login"
          }
        }
      ]
    },

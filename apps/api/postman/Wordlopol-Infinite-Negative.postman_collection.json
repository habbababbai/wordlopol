{
  "info": {
    "name": "Wordlopol Infinite (negative)",
    "description": "Edge-case and error responses for infinite mode.\n\nUses the same **Wordlopol Local** environment as the happy-path collection.\n\nRequires NODE_ENV=development (devToken on register).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3001/v1"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (pm.info.requestName.includes('[init]')) {",
          "  const runId = Date.now();",
          "  pm.environment.set('email', `inf-neg-${runId}@example.com`);",
          "  pm.environment.set('password', 'secure-password');",
          "  pm.environment.set('display_name', 'Player');",
          "  pm.environment.set('access_token', '');",
          "  pm.environment.set('verify_token', '');",
          "  console.log('[init]', pm.environment.get('email'));",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "01 No auth → 401",
      "item": [
        {
          "name": "Neg Inf 01 GET /infinite/next without Bearer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('Unauthorized', () => {",
                  "  pm.expect(pm.response.json().error).to.eql('Unauthorized');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/infinite/next"
          }
        }
      ]
    },
    {
      "name": "02 Unverified user → 403",
      "item": [
        {
          "name": "Neg Inf 02 [init] Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.test('devToken present', () => pm.expect(body.devToken).to.be.a('string').and.not.empty);",
                  "pm.test('devAccessToken present', () => pm.expect(body.devAccessToken).to.be.a('string').and.not.empty);",
                  "pm.environment.set('verify_token', body.devToken);",
                  "pm.environment.set('access_token', body.devAccessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"displayName\": \"{{display_name}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/auth/register"
          }
        },
        {
          "name": "Neg Inf 03 Login before verify",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 403', () => pm.response.to.have.status(403));",
                  "pm.test('Email not verified on login', () => {",
                  "  pm.expect(pm.response.json().error).to.eql('Email not verified');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/auth/login"
          }
        },
        {
          "name": "Neg Inf 04 Unverified user hits /infinite/next",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const accessToken = pm.environment.get('access_token');",
                  "if (!accessToken) {",
                  "  throw new Error('access_token is empty — run Neg Inf 02 [init] Register first');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 403', () => pm.response.to.have.status(403));",
                  "pm.test('Email not verified', () => {",
                  "  pm.expect(pm.response.json().error).to.eql('Email not verified');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/infinite/next"
          }
        }
      ]
    },
    {
      "name": "03 Guess errors",
      "item": [
        {
          "name": "Neg Inf 05 POST /infinite/guess without Bearer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('Unauthorized', () => {",
                  "  pm.expect(pm.response.json().error).to.eql('Unauthorized');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"guess\": \"mleko\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/infinite/guess"
          }
        },
        {
          "name": "Neg Inf 06 Unverified user hits /infinite/guess",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const accessToken = pm.environment.get('access_token');",
                  "if (!accessToken) {",
                  "  throw new Error('access_token is empty — run Neg Inf 02 [init] Register first');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 403', () => pm.response.to.have.status(403));",
                  "pm.test('Email not verified', () => {",
                  "  pm.expect(pm.response.json().error).to.eql('Email not verified');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"guess\": \"mleko\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/infinite/guess"
          }
        },
        {
          "name": "Neg Inf 07 [init] Register verified user",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.environment.set('verify_token', body.devToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"displayName\": \"{{display_name}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/auth/register"
          }
        },
        {
          "name": "Neg Inf 08 Verify email",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{verify_token}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/auth/verify-email"
          }
        },
        {
          "name": "Neg Inf 09 Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.environment.set('access_token', pm.response.json().accessToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/auth/login"
          }
        },
        {
          "name": "Neg Inf 10 POST /infinite/guess without word in progress",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('No word in progress', () => {",
                  "  pm.expect(pm.response.json().error).to.eql('No word in progress');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"guess\": \"mleko\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{base_url}}/infinite/guess"
          }
        }
      ]
    }
  ]
}

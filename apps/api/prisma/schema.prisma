generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

enum GameMode {
  DAILY
  INFINITE
  TIMED
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String
  displayName     String
  emailVerifiedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  refreshTokens           RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  gameResults             GameResult[]
  stats                   UserStats?
  infinitePlayerDays      InfinitePlayerDay[]
  infiniteWordUsages      InfiniteWordUsage[]
  dailyPlayerDays         DailyPlayerDay[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Word {
  id     Int    @id @default(autoincrement())
  text   String @unique
  length Int

  dailyChallenges     DailyChallenge[]
  dailyWordPools      DailyWordPool[]
  infinitePlayerDays  InfinitePlayerDay[] @relation("CurrentInfiniteWord")
  infiniteWordUsages  InfiniteWordUsage[]
}

model DailyChallenge {
  id     Int      @id @default(autoincrement())
  date   DateTime @unique @db.Date
  wordId Int

  word Word @relation(fields: [wordId], references: [id])

  gameResults GameResult[]
}

model DailyWordPool {
  id     Int      @id @default(autoincrement())
  date   DateTime @db.Date
  wordId Int
  order  Int

  word Word @relation(fields: [wordId], references: [id])

  @@unique([date, order])
  @@index([date])
}

model DailyPlayerDay {
  userId     String
  date       DateTime @db.Date
  guessCount Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, date])
}

model InfinitePlayerDay {
  userId        String
  date          DateTime @db.Date
  cycleNumber   Int      @default(0)
  currentWordId Int?
  guessCount    Int      @default(0)

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  word Word? @relation("CurrentInfiniteWord", fields: [currentWordId], references: [id], onDelete: SetNull)

  @@id([userId, date])
}

model InfiniteWordUsage {
  userId      String
  date        DateTime @db.Date
  cycleNumber Int
  wordId      Int

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  word Word @relation(fields: [wordId], references: [id], onDelete: Restrict)

  @@unique([userId, date, cycleNumber, wordId])
  @@index([userId, date, cycleNumber])
}

model GameResult {
  id               String    @id @default(uuid())
  userId           String
  mode             GameMode
  won              Boolean
  guesses          Int
  durationMs       Int?
  playedAt         DateTime  @default(now())
  dailyChallengeId Int?

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyChallenge DailyChallenge? @relation(fields: [dailyChallengeId], references: [id])

  @@index([userId])
  @@index([userId, mode])
}

model UserStats {
  userId           String  @id
  dailyPlayed      Int     @default(0)
  dailyWon         Int     @default(0)
  infinitePlayed   Int     @default(0)
  infiniteWon      Int     @default(0)
  bestTimedWords   Int?
  bestTimedMs      Int?
  bestTimedWord    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

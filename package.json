{
  "name": "wordlopol",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "validate:branch": "bash scripts/validate-branch-name.sh",
    "validate": "pnpm validate:branch && pnpm format:check && pnpm lint && pnpm typecheck",
    "db:migrate": "pnpm --filter @wordlopol/api db:migrate",
    "db:import-words": "pnpm --filter @wordlopol/api db:import-words",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "eslint": "^9.22.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md,yml,yaml}": "prettier --write",
    "apps/api/**/*.{ts,js}": "eslint --fix --no-warn-ignored --config apps/api/eslint.config.js",
    "apps/web/**/*.{ts,tsx}": "eslint --fix --no-warn-ignored --config apps/web/eslint.config.js",
    "packages/shared/**/*.{ts,js}": "eslint --fix --no-warn-ignored --config packages/shared/eslint.config.js"
  }
}
